{
  /* Visit https://firebase.google.com/docs/database/security to learn more about security rules. */
  "rules": {
    ".read": "false",
    ".write": "false",
    "games": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },
    "roomHostDisconnects": {
      "$gameId": {
        ".read": "auth !== null",
        ".write": "auth !== null"
      }
    },
    "gamesList": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },
    "users": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    },
    "config": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    }
  }
}
